{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vLLM Factory Benchmark Report",
  "type": "object",
  "required": ["benchmark_name", "model", "commit", "environment", "metrics"],
  "properties": {
    "benchmark_name": { "type": "string" },
    "model": { "type": "string" },
    "commit": { "type": "string" },
    "notes": { "type": "string" },
    "environment": {
      "type": "object",
      "required": ["python", "platform", "torch", "vllm"],
      "properties": {
        "python": { "type": "string" },
        "platform": { "type": "string" },
        "torch": { "type": "string" },
        "vllm": { "type": "string" },
        "gpu": { "type": "string" }
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["batch_size", "req_per_sec", "p50_ms", "p95_ms", "p99_ms"],
        "properties": {
          "batch_size": { "type": "integer", "minimum": 1 },
          "req_per_sec": { "type": "number" },
          "p50_ms": { "type": "number" },
          "p95_ms": { "type": "number" },
          "p99_ms": { "type": "number" }
        }
      }
    }
  }
}
